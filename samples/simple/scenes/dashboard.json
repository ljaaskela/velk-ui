{
  "version": 1,
  "objects": [
    { "id": "scene_root", "class": "velk-ui.Element" },
    { "id": "camera", "class": "velk-ui.Element" },
    { "id": "camera_3d", "class": "velk-ui.Element" },
    { "id": "root", "class": "velk-ui.Element" },
    { "id": "header", "class": "velk-ui.Element" },
    { "id": "logo", "class": "velk-ui.Element" },
    { "id": "body", "class": "velk-ui.Element" },
    { "id": "sidebar", "class": "velk-ui.Element" },
    { "id": "nav1", "class": "velk-ui.Element" },
    { "id": "nav2", "class": "velk-ui.Element" },
    { "id": "nav3", "class": "velk-ui.Element" },
    { "id": "content", "class": "velk-ui.Element" },
    { "id": "card1", "class": "velk-ui.Element" },
    { "id": "card2", "class": "velk-ui.Element" },
    { "id": "card3", "class": "velk-ui.Element" },
    { "id": "card4", "class": "velk-ui.Element" },
    { "id": "content_texture", "class": "velk-render.RenderTexture" },
    { "id": "rtt_display", "class": "velk-ui.Element" }
  ],
  "hierarchies": {
    "scene": {
      "scene_root": ["root", "camera", "camera_3d", "rtt_display"],
      "root": ["header", "body"],
      "body": ["sidebar", "content"],
      "sidebar": ["nav1", "nav2", "nav3", "logo"],
      "content": ["card1", "card2", "card3", "card4"]
    }
  },
  "resources": [
    { "id": "sky", "uri": "env:app://assets/qwantani_dusk_1_puresky_4k.hdr", "persistent": true }
  ],
  "attachments": [
    { "targets": ["camera"],     "class": "velk-ui.Camera" },
    { "targets": ["camera_3d"], "class": "velk-ui.Camera", "properties": { "projection": 1, "fov": 45.0, "far_clip": 5000.0, "environment": { "ref": "resources.sky" } } },
    { "targets": ["camera_3d"], "class": "velk-ui.Orbit", "properties": { "target": { "ref": "card3", "type": "weak" }, "distance": 1200.0, "yaw": 30.0, "pitch": 15.0 } },
    { "targets": ["root"],    "class": "velk-ui.Stack", "properties": { "axis": 1, "spacing": 0 } },
    { "targets": ["body"],    "class": "velk-ui.Stack", "properties": { "axis": 0, "spacing": 0 } },
    { "targets": ["sidebar"], "class": "velk-ui.Stack", "properties": { "axis": 1, "spacing": 4 } },
    { "targets": ["content"], "class": "velk-ui.Stack", "properties": { "axis": 1, "spacing": 16 } },

    { "targets": ["header"],  "class": "velk-ui.FixedSize", "properties": { "height": "48px" } },
    { "targets": ["logo"],    "class": "velk-ui.FixedSize", "properties": { "width": "64px", "height": "64px" } },
    { "targets": ["logo"],    "class": "velk-image.ImageVisual", "properties": { "uri": "image:app://scenes/images/velk-icon.png" } },
    { "targets": ["sidebar"], "class": "velk-ui.FixedSize", "properties": { "width": "180px" } },
    { "targets": ["nav1", "nav2", "nav3"], "class": "velk-ui.FixedSize", "properties": { "height": "40px" } },
    { "targets": ["card1", "card2", "card3", "card4"], "class": "velk-ui.FixedSize", "properties": { "height": "120px" } },
    { "targets": ["content"], "class": "velk-ui.RenderCache", "properties": { "render_target": { "ref": "content_texture" } } },

    { "targets": ["header"],  "class": "velk-ui.RectVisual",        "properties": { "color": { "r": 0.1, "g": 0.1, "b": 0.15, "a": 0.7 } } },
    { "targets": ["sidebar"], "class": "velk-ui.RectVisual",        "properties": { "color": { "r": 0.06, "g": 0.06, "b": 0.10, "a": 0.6 } } },
    { "targets": ["nav1"],    "class": "velk-ui.RoundedRectVisual", "properties": { "color": { "r": 0.3, "g": 0.4, "b": 0.7, "a": 0.5 } } },
    { "targets": ["nav2", "nav3"],    "class": "velk-ui.RoundedRectVisual", "properties": { "color": { "r": 0.15, "g": 0.15, "b": 0.22, "a": 0.4 } } },
    { "targets": ["card1", "card2", "card3", "card4"],   "class": "velk-ui.RoundedRectVisual", "properties": { "color": { "r": 0.12, "g": 0.14, "b": 0.22, "a": 0.35 } } },

    { "targets": ["header"],  "class": "velk-text.TextVisual", "properties": { "text": "Dashboard", "h_align": "center", "v_align": "center", "color": { "r": 0.85, "g": 0.85, "b": 0.9, "a": 1.0 } } },
    { "targets": ["nav1"],    "class": "velk-text.TextVisual", "properties": { "text": "Overview", "v_align": "center", "color": { "r": 0.9, "g": 0.9, "b": 0.95, "a": 1.0 } } },
    { "targets": ["nav2"],    "class": "velk-text.TextVisual", "properties": { "text": "Analytics", "v_align": "center", "color": { "r": 0.6, "g": 0.6, "b": 0.65, "a": 1.0 } } },
    { "targets": ["nav3"],    "class": "velk-text.TextVisual", "properties": { "text": "Settings", "v_align": "center", "color": { "r": 0.6, "g": 0.6, "b": 0.65, "a": 1.0 } } },
    { "targets": ["card1"],   "class": "velk-text.TextVisual", "properties": { "text": "Total Users",     "font_size": 16.0,  "v_align": "center", "color": { "r": 0.7, "g": 0.7, "b": 0.75, "a": 1.0 } } },
    { "targets": ["card2"],   "class": "velk-text.TextVisual", "properties": { "text": "Revenue",         "font_size": 32.0,  "v_align": "center", "color": { "r": 0.7, "g": 0.7, "b": 0.75, "a": 1.0 } } },
    { "targets": ["card3"],   "class": "velk-text.TextVisual", "properties": { "text": "Active Sessions", "font_size": 64.0,  "v_align": "center", "color": { "r": 0.7, "g": 0.7, "b": 0.75, "a": 1.0 } } },
    { "targets": ["card4"],   "class": "velk-text.TextVisual", "properties": { "text": "Uptime",          "font_size": 128.0, "v_align": "center", "color": { "r": 0.7, "g": 0.7, "b": 0.75, "a": 1.0 } } },

    { "targets": ["rtt_display"], "class": "velk-ui.FixedSize", "properties": { "width": "400px", "height": "300px" } },
    { "targets": ["rtt_display"], "class": "velk-ui.Trs", "properties": { "translate": { "x": 50, "y": 400, "z": 0 } } },
    { "targets": ["rtt_display"], "class": "velk-ui.RectVisual", "properties": { "color": { "r": 1.0, "g": 0.0, "b": 0.0, "a": 0.5 } } },
    { "targets": ["rtt_display"], "class": "velk-ui.TextureVisual", "properties": { "texture": { "ref": "content_texture" } } }
  ]
}
