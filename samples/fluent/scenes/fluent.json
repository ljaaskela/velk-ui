{
  "version": 1,
  "comment": "Fluent RT demo placeholder scene. Step 7 of design-notes/fluent_demo.md populates this with floating cards, a calendar-of-mirrors, accent geometry, floor plane.",
  "objects": [
    { "id": "scene_root", "class": "velk-ui.Element" },
    { "id": "camera_3d",  "class": "velk-ui.Element" }
  ],
  "hierarchies": {
    "scene": {
      "scene_root": ["camera_3d"]
    }
  },
  "resources": [
    { "id": "sky", "uri": "env:app://assets/qwantani_dusk_1_puresky_4k.hdr", "persistent": true }
  ],
  "attachments": [
    { "targets": ["camera_3d"], "class": "velk-ui.Camera",
      "properties": { "projection": 1, "fov": 45.0, "far_clip": 5000.0,
                      "environment": { "ref": "resources.sky" } } },
    { "targets": ["camera_3d"], "class": "velk-ui.Orbit",
      "properties": { "target": { "ref": "scene_root", "type": "weak" },
                      "distance": 1500.0, "yaw": 0.0, "pitch": 10.0 } }
  ]
}
