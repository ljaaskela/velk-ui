{
  "version": 1,
  "comment": "Fluent RT demo. Camera + env + floor + empty grid root. The mirror grid and the floor's StandardMaterial are wired up in main.cpp.",
  "objects": [
    { "id": "scene_root", "class": "velk-ui.Element" },
    { "id": "camera_3d",  "class": "velk-ui.Element" },
    { "id": "floor",      "class": "velk-ui.Element" },
    { "id": "grid_root",  "class": "velk-ui.Element" }
  ],
  "hierarchies": {
    "scene": {
      "scene_root": ["camera_3d", "floor", "grid_root"]
    }
  },
  "resources": [
    { "id": "sky", "uri": "env:app://assets/qwantani_dusk_1_puresky_4k.hdr", "persistent": true }
  ],
  "attachments": [
    { "targets": ["camera_3d"], "class": "velk-ui.Camera",
      "properties": { "projection": 1, "fov": 45.0, "far_clip": 10000.0,
                      "environment": { "ref": "resources.sky" } } },
    { "targets": ["camera_3d"], "class": "velk-ui.Orbit",
      "properties": { "target": { "ref": "grid_root", "type": "weak" },
                      "distance": 1800.0, "yaw": 0.0, "pitch": 20.0 } },

    { "targets": ["floor"], "class": "velk-ui.FixedSize",
      "properties": { "width": "4000px", "height": "4000px" } },
    { "targets": ["floor"], "class": "velk-ui.Trs",
      "properties": { "translate": { "x": -2000, "y": 700, "z": -2000 },
                      "rotation":  { "x": 90, "y": 0, "z": 0 } } },
    { "targets": ["floor"], "class": "velk-ui.RectVisual",
      "properties": { "color": { "r": 0.5, "g": 0.5, "b": 0.5, "a": 1.0 } } }
  ]
}
